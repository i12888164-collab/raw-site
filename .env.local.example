# Supabase — Project URL (БЕЗ суффикса /rest/v1/)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase — anon/public key (Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Supabase — service_role key (СЕКРЕТНЫЙ, только на сервере)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Пароль админки — минимум 12 символов, длинный случайный
ADMIN_PASSWORD=change-me-to-a-strong-random-password

# Секрет для подписи сессии админа (минимум 16 случайных символов).
# Если не задан — используется производный от ADMIN_PASSWORD (менее безопасно).
ADMIN_SESSION_SECRET=change-me-to-a-long-random-session-secret

# Ссылка на Telegram-канал/админа
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/your_admin

# Номер WhatsApp в формате 998xxxxxxxxx
NEXT_PUBLIC_WHATSAPP_NUMBER=998000000000
